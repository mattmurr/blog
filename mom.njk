---
permalink: /mom/
layout: base
title: Happy Mother's Day!
---
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Lato:wght@300;400&display=swap" rel="stylesheet">

<style>
    /* Styling for the wrapper so it integrates with base layout but keeps the card feel */
    .mom-container {
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 40px 20px;
        min-height: 80vh;
        font-family: 'Lato', sans-serif;
        background: linear-gradient(135deg, #fff0f5, #ffe4e1);
        border-radius: 12px;
        margin-top: 20px;
        position: relative;
        overflow: hidden;
    }
    .card {
        background: rgba(255, 255, 255, 0.85);
        padding: 50px 70px;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(209, 73, 91, 0.15);
        z-index: 10;
        border: 2px solid #ffb6c1;
        backdrop-filter: blur(5px);
        animation: fadeIn 2s ease-in-out;
        max-width: 600px;
        width: 100%;
    }
    .card h1 {
        font-family: 'Great Vibes', cursive;
        color: #d1495b;
        font-size: 5rem;
        margin: 0 0 15px 0;
        font-weight: normal;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.05);
        line-height: 1.1;
    }
    .photo {
        max-width: 100%;
        height: auto;
        max-height: 400px;
        border-radius: 15px;
        margin: 15px 0 25px 0;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        object-fit: cover;
    }
    .card p {
        color: #666;
        font-size: 1.6rem;
        margin: 0;
        letter-spacing: 1px;
    }
    .petal {
        position: absolute;
        border-radius: 150% 0 150% 0;
        opacity: 0.8;
        box-shadow: 0 0 5px rgba(0,0,0,0.1);
        animation: fall linear infinite;
        z-index: 1;
        top: -50px;
        pointer-events: none;
    }
    @keyframes fall {
        0% { transform: translateY(0) translateX(0) rotate(0deg); opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { transform: translateY(100vh) translateX(100px) rotate(360deg); opacity: 0; }
    }
    @keyframes fadeIn {
        0% { opacity: 0; transform: scale(0.95); }
        100% { opacity: 1; transform: scale(1); }
    }
    @media (max-width: 600px) {
        .card h1 { font-size: 3.5rem; }
        .card { padding: 40px 30px; }
    }
</style>

<div class="mom-container" id="petal-container">
    <div class="card">
        <h1>Happy Mother's Day!</h1>
        {% image "./assets/img/dji_mimo_20230820_174256_20230820174256_1692903930352_photo.png", "Me and Mom" %}
        <p>I love you!</p>
    </div>
</div>

<script>
    function createPetal() {
        const container = document.getElementById('petal-container');
        if (!container) return;

        const petal = document.createElement('div');
        petal.classList.add('petal');
        
        const size = Math.random() * 15 + 12; 
        const left = Math.random() * 100; 
        const duration = Math.random() * 6 + 5; 
        const delay = Math.random() * 3; 
        const rotation = Math.random() * 360; 
        
        const colors = ['#ffb7b2', '#ffdac1', '#e2f0cb', '#ff9aa2', '#fcc2d7'];
        const color = colors[Math.floor(Math.random() * colors.length)];
        
        petal.style.width = size + 'px';
        petal.style.height = size + 'px';
        petal.style.left = left + '%'; /* relative to container */
        petal.style.animationDuration = duration + 's';
        petal.style.animationDelay = delay + 's';
        petal.style.backgroundColor = color;
        petal.style.transform = `rotate(${rotation}deg)`;
        
        container.appendChild(petal);
        
        setTimeout(() => {
            petal.remove();
        }, (duration + delay) * 1000);
    }

    for (let i = 0; i < 30; i++) {
        setTimeout(createPetal, Math.random() * 2000);
    }
    setInterval(createPetal, 400);
</script>